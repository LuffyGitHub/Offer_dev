page {
  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #F5F5F5;
  color: #212121;
  line-height: 1.4;
}

text {
  vertical-align: middle;
}

button {
  border: none;
  outline: none;
}

button::after {
  border: none;
}
