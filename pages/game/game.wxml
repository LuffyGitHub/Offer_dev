<view class="container">
  <view class="level-header">
    <text class="level-title">第{{levelId}}关 · {{levelName}}</text>
    <text class="level-subtitle">{{levelSubtitle}}</text>
  </view>

  <view class="progress-section">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progressPercent}}%"></view>
    </view>
    <text class="progress-text">{{currentIndex + 1}}/{{totalQuestions}}</text>
  </view>

  <view class="question-card">
    <view class="question-number">第{{currentIndex + 1}}题</view>
    <view class="question-text">{{currentQuestion.text}}</view>
  </view>

  <view class="options-section">
    <view
      class="option-item {{optionClass(index)}}"
      wx:for="{{currentQuestion.options}}"
      wx:key="index"
      data-index="{{index}}"
      bindtap="selectOption"
    >
      <view class="option-radio">
        <view class="radio-dot {{selectedIndex === index ? 'active' : ''}}"></view>
      </view>
      <view class="option-label">{{item}}</view>
      <view class="option-result" wx:if="{{feedbackVisible && selectedIndex === index}}">
        <text class="result-icon">{{correctIndex === index ? '✓' : '✗'}}</text>
      </view>
    </view>
  </view>

  <view class="feedback-section" wx:if="{{feedbackVisible}}">
    <view class="feedback-card {{isCorrect ? 'correct' : 'wrong'}}">
      <text class="feedback-icon">{{isCorrect ? '🎉 回答正确！' : '😅 回答错误'}}</text>
      <text class="feedback-detail" wx:if="{{!isCorrect}}">正确答案是：{{currentQuestion.options[currentQuestion.answer]}}</text>
    </view>
    <button class="next-btn" bindtap="nextQuestion">
      <text class="next-btn-text">{{isLastQuestion ? '查看结果' : '下一题'}}</text>
    </button>
  </view>
</view>
