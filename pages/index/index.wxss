.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(180deg, #E8F0FE 0%, #F5F7FA 40%);
  box-sizing: border-box;
}

.header-animation {
  margin-bottom: 20rpx;
}

.icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.3);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.icon-text {
  font-size: 72rpx;
}

.title-section {
  margin-bottom: 20rpx;
  text-align: center;
}

.main-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #2C3E50;
  letter-spacing: 4rpx;
  display: block;
}

.sub-title {
  font-size: 30rpx;
  color: #7F8C8D;
  margin-top: 10rpx;
  display: block;
}

.desc-section {
  margin-bottom: 40rpx;
  text-align: center;
}

.desc-text {
  font-size: 26rpx;
  color: #95A5A6;
  display: block;
  line-height: 1.6;
}

.features {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 50rpx;
  width: 100%;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.feature-emoji {
  font-size: 48rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #555;
  font-weight: 500;
}

.levels-preview {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 50rpx;
}

.level-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #FFFFFF;
  padding: 28rpx 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.level-badge {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.level-badge.level1 { background: linear-gradient(135deg, #F39C12, #E67E22); }
.level-badge.level2 { background: linear-gradient(135deg, #3498DB, #2980B9); }
.level-badge.level3 { background: linear-gradient(135deg, #E74C3C, #C0392B); }

.level-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.level-info {
  flex: 1;
}

.level-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  display: block;
}

.level-desc {
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 4rpx;
  display: block;
}

.start-btn {
  width: 70%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  border-radius: 48rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.35);
}

.btn-text {
  font-size: 34rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.start-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.footer-text {
  font-size: 22rpx;
  color: #BDC3C7;
}
