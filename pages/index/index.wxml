<view class="container">
  <!-- 用户信息栏 -->
  <view class="user-header">
    <view class="user-avatar" bindtap="goProfile">
      <image class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" wx:if="{{userInfo.avatarUrl}}" />
      <text class="avatar-placeholder" wx:else>{{userInfo.nickName ? userInfo.nickName[0] : '?'}}</text>
    </view>
    <view class="user-meta">
      <text class="user-name">{{userInfo.nickName || '用户'}}</text>
      <view class="user-rank">
        <text class="rank-icon">{{rank.icon}}</text>
        <text class="rank-name" style="color: {{rank.color}}">{{rank.name}}</text>
      </view>
    </view>
    <view class="score-box" bindtap="goRanking">
      <text class="score-num">{{score}}</text>
      <text class="score-label">积分</text>
    </view>
  </view>

  <!-- 进度概览 -->
  <view class="progress-overview">
    <text class="resume-text">{{resumeText}}</text>
    <view class="progress-bar"><view class="progress-fill" style="width: {{progressPercent}}%"></view></view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="doSignIn">
      <text class="action-icon">{{signedIn ? '✅' : '📅'}}</text>
      <text class="action-text">{{signedIn ? '已签到' : '每日签到'}}</text>
    </view>
    <view class="action-item" bindtap="goWrongBook">
      <text class="action-icon">📖</text><text class="action-text">错题本</text>
    </view>
    <view class="action-item" bindtap="goBadges">
      <text class="action-icon">🏅</text><text class="action-text">勋章墙</text>
    </view>
    <view class="action-item" bindtap="goRanking">
      <text class="action-icon">🏆</text><text class="action-text">排行榜</text>
    </view>
  </view>

  <!-- 关卡列表 -->
  <text class="section-title">闯关地图</text>
  <view class="levels-list">
    <view class="level-card {{item.status}}" wx:for="{{levelList}}" wx:key="id" data-id="{{item.id}}" bindtap="startGame">
      <view class="level-badge level{{item.id}}">
        <text class="level-num">{{item.id}}</text>
      </view>
      <view class="level-info">
        <text class="level-name">{{item.name}}</text>
        <text class="level-desc">{{item.desc}}</text>
      </view>
      <view class="level-status">
        <text wx:if="{{item.status === 'completed'}}">✅</text>
        <text wx:elif="{{item.status === 'available'}}">▶</text>
        <text wx:else>🔒</text>
      </view>
    </view>
  </view>

  <button class="start-btn" bindtap="startGame">开始闯关</button>
</view>
