.container { min-height: 100vh; padding: 24rpx; background: #F5F5F5; box-sizing: border-box; }

.page-desc { font-size: 24rpx; color: #9E9E9E; display: block; margin-bottom: 24rpx; }

.badge-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.badge-card {
  background: #FFF;
  padding: 32rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.badge-card.locked { opacity: 0.5; }

.badge-icon-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #E0F7F4;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.badge-card.locked .badge-icon-wrapper { background: #E0E0E0; }

.badge-icon { font-size: 48rpx; }

.badge-name { font-size: 26rpx; font-weight: 600; color: #212121; display: block; margin-bottom: 6rpx; }
.badge-desc { font-size: 20rpx; color: #9E9E9E; display: block; line-height: 1.4; margin-bottom: 12rpx; }
.badge-reward { font-size: 20rpx; color: #00BFA5; font-weight: 500; }
.badge-reward.locked { color: #9E9E9E; }
