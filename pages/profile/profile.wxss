.container { min-height: 100vh; padding: 0 0 40rpx; background: #F5F5F5; box-sizing: border-box; }

.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 36rpx;
  background: linear-gradient(135deg, #00BFA5, #00A890);
  border-radius: 0 0 40rpx 40rpx;
}

.user-avatar { width: 120rpx; height: 120rpx; border-radius: 50%; flex-shrink: 0; }
.user-avatar-placeholder { width: 120rpx; height: 120rpx; border-radius: 50%; background: rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: #FFF; font-weight: 700; flex-shrink: 0; }

.user-detail { flex: 1; }
.user-name { font-size: 34rpx; font-weight: 600; color: #FFF; display: block; }
.user-grade { font-size: 22rpx; color: rgba(255,255,255,0.8); display: block; margin-top: 4rpx; }
.user-rank { display: flex; align-items: center; gap: 10rpx; margin-top: 8rpx; }
.rank-icon { font-size: 28rpx; }
.rank-name { font-size: 24rpx; font-weight: 600; }
.rank-score { font-size: 22rpx; color: rgba(255,255,255,0.8); margin-left: auto; }

.section-card { background: #FFF; margin: 24rpx 24rpx 0; padding: 28rpx; border-radius: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.section-title { font-size: 28rpx; font-weight: 600; color: #212121; display: block; margin-bottom: 20rpx; }

.radar-box { display: flex; flex-direction: column; gap: 16rpx; }
.radar-row { display: flex; align-items: center; gap: 16rpx; }
.radar-label { width: 140rpx; font-size: 24rpx; color: #616161; }
.radar-bar { flex: 1; height: 16rpx; background: #E0E0E0; border-radius: 8rpx; overflow: hidden; }
.radar-fill { height: 100%; background: linear-gradient(90deg, #00BFA5, #FFAB00); border-radius: 8rpx; }
.radar-value { width: 60rpx; font-size: 22rpx; color: #00BFA5; font-weight: 500; text-align: right; }

.stats-grid {
  display: flex;
  margin: 24rpx 24rpx 0;
  gap: 16rpx;
}

.stats-item {
  flex: 1;
  background: #FFF;
  padding: 24rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.stats-num { font-size: 40rpx; font-weight: 800; color: #00BFA5; display: block; }
.stats-label { font-size: 22rpx; color: #9E9E9E; margin-top: 4rpx; display: block; }

.menu-list { margin: 24rpx 24rpx 0; background: #FFF; border-radius: 20rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.menu-item { display: flex; align-items: center; padding: 28rpx 24rpx; border-bottom: 1rpx solid #F5F5F5; }
.menu-icon { font-size: 32rpx; margin-right: 16rpx; }
.menu-text { flex: 1; font-size: 28rpx; color: #212121; }
.menu-arrow { font-size: 36rpx; color: #9E9E9E; }
