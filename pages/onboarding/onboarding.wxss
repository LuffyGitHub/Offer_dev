.container {
  min-height: 100vh;
  padding: 40rpx 36rpx;
  background: #F5F5F5;
  box-sizing: border-box;
}

.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.step {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step.active { background: #00BFA5; }

.step-num { font-size: 26rpx; color: #FFF; font-weight: 600; }

.step-line {
  width: 60rpx;
  height: 4rpx;
  background: #E0E0E0;
  border-radius: 2rpx;
}

.step-line.active { background: #00BFA5; }

.step-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #212121;
  text-align: center;
  margin-bottom: 40rpx;
}

.form-group { margin-bottom: 32rpx; }

.form-label {
  font-size: 28rpx;
  color: #424242;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.picker-box {
  background: #FFF;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #212121;
  border: 2rpx solid #E0E0E0;
}

.quiz-section { width: 100%; }

.quiz-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.quiz-q-num { font-size: 26rpx; color: #00BFA5; font-weight: 600; white-space: nowrap; }

.quiz-progress {
  flex: 1;
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
  overflow: hidden;
}

.quiz-progress-fill {
  height: 100%;
  background: #00BFA5;
  border-radius: 4rpx;
}

.quiz-question {
  font-size: 32rpx;
  color: #212121;
  line-height: 1.6;
  margin-bottom: 30rpx;
  font-weight: 500;
}

.quiz-options { display: flex; flex-direction: column; gap: 20rpx; }

.quiz-option {
  background: #FFF;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E0E0E0;
  font-size: 28rpx;
  color: #424242;
}

.quiz-option.selected {
  border-color: #00BFA5;
  background: #E0F7F4;
  color: #00BFA5;
  font-weight: 500;
}

.guide-section { display: flex; flex-direction: column; gap: 24rpx; margin-bottom: 40rpx; }

.guide-card {
  background: #FFF;
  padding: 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.guide-icon { font-size: 56rpx; margin-bottom: 12rpx; }
.guide-text { font-size: 30rpx; font-weight: 600; color: #212121; }
.guide-desc { font-size: 24rpx; color: #9E9E9E; margin-top: 6rpx; }

.next-btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #00BFA5, #00A890);
  border-radius: 44rpx;
  text-align: center;
  position: fixed;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  box-shadow: 0 6rpx 24rpx rgba(0,191,165,0.3);
  font-size: 32rpx;
  color: #FFF;
  font-weight: 600;
}
