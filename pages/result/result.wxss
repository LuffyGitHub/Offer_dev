.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(180deg, #E0F7F4 0%, #F5F5F5 40%);
  box-sizing: border-box;
}

.result-icon-wrapper {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  animation: bounceIn 0.6s ease;
}

.result-icon-wrapper.passed {
  background: linear-gradient(135deg, #00BFA5, #00A890);
  box-shadow: 0 8rpx 40rpx rgba(0, 191, 165, 0.3);
}

.result-icon-wrapper.failed {
  background: linear-gradient(135deg, #FFAB00, #E69900);
  box-shadow: 0 8rpx 40rpx rgba(255, 171, 0, 0.3);
}

@keyframes bounceIn {
  0% { transform: scale(0); opacity: 0; }
  60% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

.result-big-icon {
  font-size: 96rpx;
}

.result-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #212121;
  margin-bottom: 8rpx;
}

.result-subtitle {
  font-size: 28rpx;
  color: #616161;
  margin-bottom: 40rpx;
}

.score-card {
  display: flex;
  align-items: center;
  gap: 32rpx;
  background: #FFFFFF;
  padding: 32rpx 48rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 30rpx;
}

.score-circle {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.score-circle.passed .score-number {
  color: #00BFA5;
}

.score-circle.failed .score-number {
  color: #FFAB00;
}

.score-number {
  font-size: 72rpx;
  font-weight: 800;
}

.score-divider {
  font-size: 40rpx;
  color: #9E9E9E;
}

.score-total {
  font-size: 40rpx;
  color: #9E9E9E;
  font-weight: 600;
}

.score-detail {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.score-label {
  font-size: 26rpx;
  color: #9E9E9E;
}

.score-comment {
  font-size: 34rpx;
  font-weight: 600;
  color: #212121;
}

.level-complete {
  margin-bottom: 50rpx;
}

.complete-text {
  font-size: 26rpx;
  color: #9E9E9E;
}

.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.action-btn {
  width: 70%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  text-align: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, #00BFA5, #00A890);
  box-shadow: 0 6rpx 24rpx rgba(0, 191, 165, 0.3);
}

.action-btn.secondary {
  background: #FFFFFF;
  border: 2rpx solid #E0E0E0;
}

.action-btn.link {
  background: transparent;
}

.action-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.action-btn-text.secondary-text {
  color: #616161;
}

.action-btn-text.link-text {
  color: #9E9E9E;
  font-weight: 400;
}

.action-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}
