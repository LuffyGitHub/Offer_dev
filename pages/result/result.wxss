.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(180deg, #F0F4F8 0%, #F5F7FA 40%);
  box-sizing: border-box;
}

.result-icon-wrapper {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  animation: bounceIn 0.6s ease;
}

.result-icon-wrapper.passed {
  background: linear-gradient(135deg, #52C41A, #73D13D);
  box-shadow: 0 8rpx 40rpx rgba(82, 196, 26, 0.3);
}

.result-icon-wrapper.failed {
  background: linear-gradient(135deg, #FAAD14, #FFC53D);
  box-shadow: 0 8rpx 40rpx rgba(250, 173, 20, 0.3);
}

@keyframes bounceIn {
  0% { transform: scale(0); opacity: 0; }
  60% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

.result-big-icon {
  font-size: 96rpx;
}

.result-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 8rpx;
}

.result-subtitle {
  font-size: 28rpx;
  color: #7F8C8D;
  margin-bottom: 40rpx;
}

.score-card {
  display: flex;
  align-items: center;
  gap: 32rpx;
  background: #FFFFFF;
  padding: 32rpx 48rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 30rpx;
}

.score-circle {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.score-circle.passed .score-number {
  color: #52C41A;
}

.score-circle.failed .score-number {
  color: #FAAD14;
}

.score-number {
  font-size: 72rpx;
  font-weight: 800;
}

.score-divider {
  font-size: 40rpx;
  color: #BDC3C7;
}

.score-total {
  font-size: 40rpx;
  color: #BDC3C7;
  font-weight: 600;
}

.score-detail {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.score-label {
  font-size: 26rpx;
  color: #95A5A6;
}

.score-comment {
  font-size: 34rpx;
  font-weight: 600;
  color: #2C3E50;
}

.level-complete {
  margin-bottom: 50rpx;
}

.complete-text {
  font-size: 26rpx;
  color: #95A5A6;
}

.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.action-btn {
  width: 70%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  text-align: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  box-shadow: 0 6rpx 24rpx rgba(74, 144, 217, 0.3);
}

.action-btn.secondary {
  background: #FFFFFF;
  border: 2rpx solid #D1D5DB;
}

.action-btn.link {
  background: transparent;
}

.action-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.action-btn-text.secondary-text {
  color: #555;
}

.action-btn-text.link-text {
  color: #95A5A6;
  font-weight: 400;
}

.action-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}
