.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(180deg, #E0F7F4 0%, #F5F5F5 40%);
  box-sizing: border-box;
}

.result-icon-wrapper {
  width: 180rpx; height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  animation: bounceIn 0.6s ease;
}
.result-icon-wrapper.passed { background: linear-gradient(135deg, #00BFA5, #00A890); box-shadow: 0 8rpx 40rpx rgba(0,191,165,0.3); }
.result-icon-wrapper.failed { background: linear-gradient(135deg, #FFAB00, #E69900); box-shadow: 0 8rpx 40rpx rgba(255,171,0,0.3); }

@keyframes bounceIn {
  0% { transform: scale(0); opacity: 0; }
  60% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

.result-big-icon { font-size: 88rpx; }

.result-title { font-size: 44rpx; font-weight: 700; color: #212121; margin-bottom: 8rpx; }
.result-subtitle { font-size: 26rpx; color: #616161; margin-bottom: 36rpx; }

.stats-card {
  display: flex;
  align-items: center;
  gap: 0;
  background: #FFF;
  padding: 28rpx 36rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 30rpx;
  width: 90%;
  box-sizing: border-box;
}

.stat-item { flex: 1; text-align: center; }
.stat-value { font-size: 44rpx; font-weight: 800; display: block; }
.stat-value.passed { color: #00BFA5; }
.stat-value.failed { color: #FFAB00; }
.stat-label { font-size: 22rpx; color: #9E9E9E; margin-top: 6rpx; display: block; }

.stat-divider { width: 2rpx; height: 60rpx; background: #E0E0E0; }

.level-complete { margin-bottom: 40rpx; }
.complete-label { font-size: 26rpx; color: #9E9E9E; }

.action-section { width: 100%; display: flex; flex-direction: column; align-items: center; gap: 20rpx; }

.action-btn {
  width: 70%; height: 84rpx; line-height: 80rpx;
  border-radius: 42rpx; text-align: center;
  font-size: 30rpx; font-weight: 600;
}

.action-btn.primary { background: linear-gradient(135deg, #00BFA5, #00A890); color: #FFF; box-shadow: 0 6rpx 24rpx rgba(0,191,165,0.3); }
.action-btn.secondary { background: #FFF; border: 2rpx solid #E0E0E0; color: #616161; }
.action-btn.link { background: transparent; color: #9E9E9E; font-weight: 400; }
